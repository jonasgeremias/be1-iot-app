{
  "expo": {
    "name": "BE1 Smart App",
    "slug": "be1-smart",
    "version": "1.28.0",
    "orientation": "portrait",
    "scheme": "be1app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.be1.app"
    },
    "android": {
      "package": "br.com.be1.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app acessa suas fotos para definir a foto de perfil.",
          "cameraPermission": "O app acessa a câmera para tirar a foto de perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
